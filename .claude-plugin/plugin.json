{
  "name": "fugaku",
  "description": "スーパーコンピュータ「富岳」を自然言語で操作するMCPサーバ（公式WebAPI × X.509証明書）",
  "version": "1.5.2",
  "author": {
    "name": "Fumiyoshi Shoji",
    "email": "shoji@riken.jp"
  },
  "homepage": "https://github.com/RIKEN-RCCS/fugaku-mcp",
  "repository": "https://github.com/RIKEN-RCCS/fugaku-mcp",
  "license": "MIT",
  "keywords": [
    "hpc",
    "fugaku",
    "supercomputer",
    "mcp",
    "riken"
  ],
  "mcpServers": {
    "fugaku": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/plugin-run.sh"
      ],
      "env": {
        "FUGAKU_CERT": "${HOME}/.fugaku/fugaku.pem"
      }
    }
  }
}